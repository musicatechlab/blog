---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page">
				<header class="page-header">
					<p class="overline">Musica Tech Lab</p>
					<h1 class="headline">Blog</h1>
					<p class="tagline">音楽と技術のあいだで考えたこと、作ったものの記録。</p>
				</header>

				<section aria-label="記事一覧">
					<ol class="post-list">
						{
							posts.map((post) => (
								<li>
									<a class="row" href={`/blog/${post.id}/`}>
										<span class="row-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="row-body">
											<span class="row-title">{post.data.title}</span>
											{post.data.description && (
												<span class="row-desc">{post.data.description}</span>
											)}
										</span>
									</a>
								</li>
							))
						}
					</ol>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page {
		max-width: var(--mtl-measure);
		margin: 0 auto;
	}

	.page-header {
		margin-bottom: var(--mtl-space-8);
	}

	.overline {
		font-size: var(--mtl-text-pp);
		font-weight: 600;
		letter-spacing: 0.32em;
		text-transform: uppercase;
		color: var(--mtl-ink-3);
		margin-bottom: var(--mtl-space-2);
	}

	.headline {
		font-family: var(--mtl-font-serif);
		font-weight: 400;
		font-size: clamp(var(--mtl-text-ff), 5vw, var(--mtl-text-fff));
		line-height: var(--mtl-leading-heading);
		margin-bottom: var(--mtl-space-2);
	}

	.tagline {
		font-size: var(--mtl-text-mf);
		color: var(--mtl-ink-2);
		margin: 0;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--mtl-line);
	}

	.row {
		display: flex;
		align-items: baseline;
		gap: var(--mtl-space-3);
		padding: var(--mtl-space-3) var(--mtl-space-1);
		border-bottom: 1px solid var(--mtl-line);
		text-decoration: none;
		transition:
			background-color var(--mtl-dur-s) var(--mtl-ease),
			padding-left var(--mtl-dur-m) var(--mtl-ease);
	}

	.row:hover {
		background: var(--mtl-paper-dim);
		padding-left: var(--mtl-space-2);
	}

	.row-date {
		font-family: var(--mtl-font-mono);
		font-size: var(--mtl-text-p);
		color: var(--mtl-ink-3);
		white-space: nowrap;
		min-width: 9ch;
	}

	.row-body {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.row-title {
		font-weight: 600;
		font-size: var(--mtl-text-mf);
		color: var(--mtl-ink);
		letter-spacing: 0.01em;
		transition: color var(--mtl-dur-s) var(--mtl-ease);
	}

	.row:hover .row-title {
		color: var(--mtl-accent);
	}

	.row-desc {
		font-size: var(--mtl-text-p);
		color: var(--mtl-ink-2);
	}

	@media (max-width: 560px) {
		.row {
			flex-direction: column;
			gap: var(--mtl-space-1);
		}
	}
</style>
