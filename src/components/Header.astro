---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="nav">
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a class="home-link" href="https://home.musicatechlab.com">MusicaTechLab →</a>
		</div>
	</nav>
</header>
<div class="mtl-staff" role="presentation"></div>

<style>
	.site-header {
		padding: var(--mtl-space-3) 0;
	}

	.nav {
		width: min(100% - var(--mtl-space-6), var(--mtl-container));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--mtl-space-2);
	}

	.brand {
		font-family: var(--mtl-font-serif);
		font-size: var(--mtl-text-mf);
		font-weight: 400;
		letter-spacing: 0.02em;
		color: var(--mtl-ink);
		text-decoration: none;
	}

	.links {
		display: flex;
		align-items: center;
		gap: var(--mtl-space-3);
	}

	.home-link {
		font-size: var(--mtl-text-p);
		color: var(--mtl-ink-3);
		text-decoration: none;
		border-bottom: none;
	}

	.home-link:hover {
		color: var(--mtl-accent);
	}

	@media (max-width: 560px) {
		.links {
			gap: var(--mtl-space-2);
		}
	}
</style>
