---
const today = new Date();
---

<footer class="site-footer">
	<p>&copy; {today.getFullYear()} MusicaTechLab</p>
	<a href="https://home.musicatechlab.com">home.musicatechlab.com</a>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--mtl-line);
		margin-top: var(--mtl-space-8);
		padding: var(--mtl-space-4) var(--mtl-space-2);
		text-align: center;
		font-size: var(--mtl-text-p);
		color: var(--mtl-ink-3);
		display: flex;
		flex-direction: column;
		gap: var(--mtl-space-1);
	}

	.site-footer a {
		color: var(--mtl-ink-3);
		text-decoration: none;
	}

	.site-footer a:hover {
		color: var(--mtl-accent);
	}
</style>
